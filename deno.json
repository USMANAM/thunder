{
  "lint": {
    "plugins": [
      "./core/lint-plugins/no-relative-core-imports.ts",
      "./core/lint-plugins/no-relative-database-imports.ts"
    ]
  },
  "tasks": {
    "check": "deno fmt && deno lint",
    "dev": "ENV_TYPE=development deno serve -A --watch serve.ts",
    "start": "ENV_TYPE=production deno serve -A serve.ts",
    "init": "rm -rf .git && git init && git config core.hooksPath .githooks && deno run -A ./core/scripts/setupEnv.ts",
    "update:core": "deno run -A ./core/scripts/updateCore.ts",
    "add:plugin": "deno run -A ./core/scripts/addPlugin.ts",
    "update:plugin": "deno run -A ./core/scripts/updatePlugin.ts",
    "remove:plugin": "deno run -A ./core/scripts/removePlugin.ts",
    "generate:openapi": "deno run -A ./core/scripts/generateOpenAPI.ts",
    "generate:sdk": "deno run -A ./core/scripts/generateSDK.ts",
    "generate:sdk:plugin": "deno run -A ./core/scripts/generateSDKPlugin.ts"
  },
  "imports": {
    "@/": "./",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0-rc.8",
    "@std/cli": "jsr:@std/cli@^1.0.25",
    "@std/collections": "jsr:@std/collections@^1.1.3",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/fs": "jsr:@std/fs@^1.0.21",
    "@std/http": "jsr:@std/http@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@types/ejs": "npm:@types/ejs@^3.1.5",
    "@types/qs": "npm:@types/qs@^6.14.0",
    "@oridune/zod-to-ts": "npm:@oridune/zod-to-ts@^2.0.1",
    "ejs": "npm:ejs@^4.0.1",
    "mongodb": "npm:mongodb@^7.0.0",
    "path-to-regexp": "npm:path-to-regexp@^8.3.0",
    "qs": "npm:qs@^6.14.1",
    "typescript": "npm:typescript@^5.9.3",
    "zod": "npm:zod@^4.3.6",
    "zod-openapi": "npm:zod-openapi@^5.4.6"
  },
  "scopes": {}
}
